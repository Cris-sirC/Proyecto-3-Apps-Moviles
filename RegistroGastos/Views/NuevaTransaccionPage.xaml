<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RegistroGastos.Views.NuevaTransaccionPage"
             Title="GASTOS">
    <Grid RowDefinitions="150, *">
        <BoxView Color="#2A0B4C" Grid.Row="0" Margin="0,0,0,20"/>
        <Label Text="Nueva transacción" TextColor="White" FontSize="24" Padding="20" VerticalOptions="Center"/>

        <Border Grid.Row="1" BackgroundColor="White" StrokeShape="RoundRectangle 15" Margin="20,-40,20,20" Padding="20">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,5" Opacity="0.1" Radius="10"/>
            </Border.Shadow>
            <VerticalStackLayout Spacing="15">
                <Label Text="Glosa" TextColor="Gray"/>
                <Entry Text="{Binding Glosa}" Placeholder="Ej: supermercado" TextColor="Black"/>
                
                <Label Text="Cantidad" TextColor="Gray"/>
                <Entry Text="{Binding Cantidad}" Keyboard="Numeric" TextColor="Black"/>
                
                <Label Text="Fecha" TextColor="Gray"/>
                <DatePicker Date="{Binding Fecha}" TextColor="Black"/>
                
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <CheckBox IsChecked="{Binding EsIngreso}" Color="#2A0B4C"/>
                    <Label Text="¿Es ingreso?" TextColor="Gray" VerticalOptions="Center"/>
                </HorizontalStackLayout>
                
                <HorizontalStackLayout Spacing="10" Margin="0,20,0,0">
                    <Button Text="Guardar" Command="{Binding GuardarCommand}" BackgroundColor="#5B3CD4" TextColor="White" CornerRadius="8"/>
                    <Button Text="Cancelar" Command="{Binding CancelarCommand}" BackgroundColor="#8B0000" TextColor="White" CornerRadius="8"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>